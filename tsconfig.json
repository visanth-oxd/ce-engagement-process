{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2020", "DOM"],
    "jsx": "react",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "types": ["node", "jest"],
    "paths": {
      "@internal/plugin-engagement-common": ["./plugins/engagement-common/src"]
    },
    "baseUrl": "."
  },
  "include": ["plugins/*/src/**/*"]
}
